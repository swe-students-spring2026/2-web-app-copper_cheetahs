# mongodb atlas (replace 'user' and 'password' with your username and password) default
MONGO_DBNAME=tasks
MONGO_URI=mongodb+srv://user:password@cluster0.weel2od.mongodb.net
FLASK_APP=app.py
FLASK_ENV=development
FLASK_PORT=5000
GUNICORN_PROCESSES=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120
GUNICORN_BIND=0.0.0.0:8080

